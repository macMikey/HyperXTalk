<?xml version="1.0" encoding="utf-8"?>
<Project xmlns="http://schemas.microsoft.com/developer/msbuild/2003">
  <PropertyGroup Condition="'$(flexBeforeTargets)' == '' and '$(flexAfterTargets)' == '' and '$(ConfigurationType)' != 'Makefile'">
    <flexBeforeTargets>Midl</flexBeforeTargets>
    <flexAfterTargets>CustomBuild</flexAfterTargets>
  </PropertyGroup>
  <PropertyGroup>
    <flexDependsOn Condition="'$(ConfigurationType)' != 'Makefile'">_SelectedFiles;$(flexDependsOn)</flexDependsOn>
  </PropertyGroup>
  <ItemDefinitionGroup>
    <flex>
      <CommandLineTemplate>call $(ProjectDir)..\..\..\..\..\util\invoke-unix.bat &quot;/usr/bin/flex&quot; &quot;-o&quot; &quot;$(IntDir)stage3\%(Filename).l.c&quot; &quot;-w&quot; &quot;%(Identity)&quot;</CommandLineTemplate>
      <Outputs>$(IntDir)stage3\%(Filename).l.c</Outputs>
      <ExecutionDescription>Lexing &quot;%(Filename)%(Extension)&quot;</ExecutionDescription>
      <AdditionalDependencies></AdditionalDependencies>
    </flex>
  </ItemDefinitionGroup>
  <PropertyGroup Condition="'$(bisonBeforeTargets)' == '' and '$(bisonAfterTargets)' == '' and '$(ConfigurationType)' != 'Makefile'">
    <bisonBeforeTargets>Midl</bisonBeforeTargets>
    <bisonAfterTargets>CustomBuild</bisonAfterTargets>
  </PropertyGroup>
  <PropertyGroup>
    <bisonDependsOn Condition="'$(ConfigurationType)' != 'Makefile'">_SelectedFiles;$(bisonDependsOn)</bisonDependsOn>
  </PropertyGroup>
  <ItemDefinitionGroup>
    <bison>
      <CommandLineTemplate>call $(ProjectDir)..\..\..\..\..\util\invoke-unix.bat &quot;/usr/bin/bison&quot; &quot;-o&quot; &quot;$(IntDir)stage3\%(Filename).y.c&quot; &quot;%(Identity)&quot;</CommandLineTemplate>
      <Outputs>$(IntDir)stage3\%(Filename).y.c</Outputs>
      <ExecutionDescription>Yaccing &quot;%(Filename)%(Extension)&quot;</ExecutionDescription>
      <AdditionalDependencies></AdditionalDependencies>
    </bison>
  </ItemDefinitionGroup>
  <PropertyGroup Condition="'$(auxiliary_grammarBeforeTargets)' == '' and '$(auxiliary_grammarAfterTargets)' == '' and '$(ConfigurationType)' != 'Makefile'">
    <auxiliary_grammarBeforeTargets>Midl</auxiliary_grammarBeforeTargets>
    <auxiliary_grammarAfterTargets>CustomBuild</auxiliary_grammarAfterTargets>
  </PropertyGroup>
  <PropertyGroup>
    <auxiliary_grammarDependsOn Condition="'$(ConfigurationType)' != 'Makefile'">_SelectedFiles;$(auxiliary_grammarDependsOn)</auxiliary_grammarDependsOn>
  </PropertyGroup>
  <ItemDefinitionGroup>
    <auxiliary_grammar>
      <CommandLineTemplate>call $(OutDir)gentle-target.exe &quot;-inputdir&quot; &quot;..\..\..\..\toolchain\lc-compile\src&quot; &quot;%(Filename).c=$(IntDir)stage3\%(Filename).c&quot; &quot;%(Identity)&quot;</CommandLineTemplate>
      <Outputs>$(IntDir)stage3\%(Filename).c</Outputs>
      <ExecutionDescription>Running gentle on auxiliary grammar &quot;%(Filename)%(Extension)&quot;</ExecutionDescription>
      <AdditionalDependencies>$(IntDir)stage3\gen.lit;$(IntDir)stage3\gen.tkn</AdditionalDependencies>
    </auxiliary_grammar>
  </ItemDefinitionGroup>
</Project>
