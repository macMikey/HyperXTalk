.PHONY : zip_utf-8.o

# target to preprocess a source file
zip_utf-8.i:
	$(MAKE) -f CMakeFiles/zip.dir/build.make CMakeFiles/zip.dir/zip_utf-8.i
.PHONY : zip_utf-8.i

# target to generate assembly for a file
zip_utf-8.s:
	$(MAKE) -f CMakeFiles/zip.dir/build.make CMakeFiles/zip.dir/zip_utf-8.s
.PHONY : zip_utf-8.s

